# cmux-fleet.toml: copy to $XDG_CONFIG_HOME/cmux-fleet/fleet.toml (default ~/.config/cmux-fleet/fleet.toml)
# or point $CMUX_FLEET_TOML at it. Every block is optional; the engine runs with no file at all
# (ad-hoc launches need no roster). Edit freely; roles are created lazily.

# ----------------------------------------------------------------------------------------------
# [fleet] engine config. Every key is optional; shown with its effective default. Precedence
# per key is: env var > this block > built-in default. (Resolved in scripts/config.py.)
# ----------------------------------------------------------------------------------------------
[fleet]
# root         = ""                 # workspace root that relative role cwds compose against.
#                                   #   "" -> $HOME. Set to "." or an absolute path for a project-local
#                                   #   layout (a normal ~/.config copy does NOT make cwds config-relative).
#                                   #   env: CMUX_FLEET_ROOT
# state_dir    = ""                 # "" -> $XDG_STATE_HOME/cmux-fleet (~/.local/state/cmux-fleet).  env: CMUX_STATE_DIR
# cmux_bin     = ""                 # "" -> `which cmux`, then the macOS app bundle.  env: CMUX_BIN
# plugin_index = ""                 # path to the plugins.toml INDEX (see plugins.toml.example); "" ->
#                                   #   <this-file's-dir>/plugins.toml. Absent file = empty index, no error.
#                                   #   The index powers the `plugins = [...]` roster key.  env: CMUX_FLEET_PLUGIN_INDEX
# floor_claudemd = ""               # LEGACY floor: a CLAUDE.md symlinked into the shared ad-hoc home; "" =
#                                   #   none. Superseded by the first-class, per-tool `[tool.<t>.floor_file]`
#                                   #   below (write/append/overwrite/symlink into cwd|home) — floor_claudemd
#                                   #   stays as the adhoc fallback ONLY when no floor_file is configured.
#                                   #   env: CMUX_FLEET_FLOOR
#                                   # (`--adhoc <name>` is now an alias for the [role.adhoc] block below —
#                                   #  one shared flat home, <name> becomes the LABEL. No adhoc_subdir key.)
# mint_identity_template = ""       # template FILE `fleet mint` seeds as the new home's CLAUDE.md; "" -> a
#                                   #   built-in THIN stub (a pointer to /loom:prime, never boot content).
#                                   #   {name}/{kind} are substituted.  env: CMUX_FLEET_MINT_IDENTITY_TEMPLATE
#                                   #   (`fleet mint <name>` DEFINES a new role: home dir + thin identity +
#                                   #    an appended [role.<name>] block; --launch also spawns it.)
# sidebar_paint = false             # daemon auto-repaints the custom fleet.swift sidebar (~every 4s, on-change)
#                                   #   so state/ctx/model/last stay live. OFF by default: it writes a FLEET
#                                   #   record into each agent workspace's DESCRIPTION (a subtitle in the
#                                   #   BUILT-IN sidebar), so only enable it when you run the custom sidebar.
#                                   #   env: CMUX_FLEET_SIDEBAR_PAINT
# boot_prompt  = ""                 # the TURN-ONE boot prompt `fleet launch` (and recycle/revive --fresh)
#                                   #   sends as the agent's first turn: it tells the agent to run
#                                   #   /loom:prime, report ready, then drain `fleet inbox` for its --brief.
#                                   #   "" -> the built-in frozen default. Override with the literal prompt
#                                   #   text (TOML triple-quote for multi-line) OR a path to a file holding
#                                   #   it; read at compose time, so an edit goes live with no tool release.
#                                   #   {AGENT_ROLE}/{AGENT_LABEL} are substituted by the launcher. ONE value
#                                   #   serves both launch and recycle. --prime overrides per-invocation.
#                                   #   env: CMUX_FLEET_BOOT_PROMPT

# ----------------------------------------------------------------------------------------------
# ROSTER: role-first, tool-nested. A role owns its tool-agnostic ORCHESTRATION (cwd/place/group/
# kind) once; thin per-tool sub-blocks carry that tool's LAUNCH CONFIG (plugins/flags/env/settings).
#   [defaults]          default tool + orchestration floor
#   [tool.<t>]          per-tool launch floor -> the adapter's defaults
#   [role.<name>]       orchestration (cwd/place/group/kind) + the role's default tool
#   [role.<name>.<t>]   that role's config for tool <t>
# Native flags go RAW in `flags` (e.g. "--model opus --effort high"); the launcher forwards them
# without knowing them. `cwd` is relative to [fleet].root (or absolute). AGENT_ROLE/AGENT_LABEL are
# auto-set. `plugins` names resolve through the plugins.toml index (or an absolute path).
# ----------------------------------------------------------------------------------------------
[defaults]
tool  = "claude"
kind  = "child"
place = "tab"

[tool.claude]
# plugins = ["cmux-fleet"]          # give every claude agent the conductor toolkit. Names resolve through
#                                   #   the INDEX (plugins.toml) — the index says linked (--plugin-dir) vs
#                                   #   enabled (enabledPlugins), so you don't pick the mechanism here. A
#                                   #   name must be in the index (via a [marketplace.<n>] block) or be an
#                                   #   absolute path. Unioned floor ∪ role.
flags   = "--effort high"

# [tool.claude.floor_file]          # F1: a floor FILE fleet PLACES into the agent's cwd (or home) at launch,
#                                   #   so a vendored install with no vault-root CLAUDE.md still delivers a
#                                   #   floor, declaratively. It only PLACES the file; claude LOADS it via
#                                   #   your setting_sources project walk (set `setting_sources` to include
#                                   #   `project` below). A per-role override lives in [role.<n>.claude.floor_file].
# source   = "~/floor/CLAUDE.floor.md"   # a PATH to a file, OR literal inline content (like boot_prompt).
#                                        #   Shorthand: `floor_file = "~/floor/CLAUDE.floor.md"` = just source.
# mode     = "append"               # append | write | overwrite | symlink. DEFAULT append: a fenced,
#                                   #   marker-guarded block — never clobbers your own text, idempotent so a
#                                   #   re-launch never duplicates. write = place only into an empty slot
#                                   #   (skip+warn if a file exists). overwrite = replace the whole file (the
#                                   #   only clobbering mode). symlink = a relative symlink (skip if a real
#                                   #   file exists); source must be a FILE, not inline.
# target   = "cwd"                  # cwd | home. DEFAULT is per-tool: claude -> cwd, codex -> home. `home` is
#                                   #   ~/.claude/CLAUDE.md for claude, $CODEX_HOME/AGENTS.md for codex.
# filename = "CLAUDE.md"            # override the per-tool default filename (claude CLAUDE.md, codex AGENTS.md).

[tool.codex]
# flags = "-a never -s workspace-write"   # never-prompt but sandboxed; codex's autonomous-worker posture
#
# PIN THE MODEL + EFFORT HERE. With no --model/--effort on the codex floor, a codex agent falls through to
# the Codex DESKTOP APP's own ~/.codex/config.toml (`model` / `model_reasoning_effort`) — so changing the
# model in the desktop app silently moves your whole codex fleet, and a recycle rides whatever the ambient
# default happens to be rather than a fixed identity. Pin it and the agent is reproducible:
#
#   flags = "--dangerously-bypass-approvals-and-sandbox --model gpt-5.6-sol --effort xhigh"
#
# Write it in CLAUDE syntax (--model/--effort): the codex adapter translates at the boundary
# (--effort <lvl> -> `-c model_reasoning_effort=<lvl>`; --model passes through natively).
# Roles override in [role.<name>.codex].flags.
#
# THE CONTEXT WINDOW IS A PROPERTY OF THE MODEL — there is no window flag and no window config key to set.
# codex-cli ships a model registry (embedded in the binary; read it with:
#   strings $(readlink -f $(which codex)) | grep -A30 '"slug": "gpt-5.6-sol"'
# ) and each slug fixes its own window. In codex-cli 0.144.1:
#
#   slug            nominal ctx   max ctx    notes
#   gpt-5.6-sol       372_000     372_000    "Latest frontier agentic coding model" — the 5.5 replacement
#   gpt-5.6-terra     372_000     372_000    balanced/everyday
#   gpt-5.6-luna      372_000     372_000    fast + affordable
#   gpt-5.5           272_000     272_000    the previous frontier pin
#   gpt-5.4           272_000   1_000_000    the ONLY slug with headroom past its default — but a weaker model
#
# Two things that bite:
#   1. For every gpt-5.6-* variant, nominal == max, so there is NOTHING to raise: you get the window by
#      CHOOSING THE MODEL. (`model_context_window` exists as a codex config field, but on 5.6 it has no
#      headroom to buy, and setting it above the true window only lies to codex's own compaction/display.)
#   2. NOMINAL IS NOT EFFECTIVE. The window the server actually grants is smaller than the registry's
#      number and is reported per-turn in the rollout as `info.model_context_window` — live-measured
#      353_400 for gpt-5.6-sol (vs 258_400 for gpt-5.5). `fleet vitals` reads that rollout value, so it
#      shows the REAL denominator, not the brochure one. Trust vitals over this table.
#
# Efforts: 5.6-sol/terra also accept `max` and `ultra` above `xhigh` (5.5 topped out at xhigh).

# --- example roles ----------------------------------------------------------------------------
# THE scratch role. `fleet launch --adhoc <name>` is an alias for `launch adhoc --label <name>`: every
# ad-hoc agent shares this ONE flat home (differentiated by label, not a per-name dir), and inherits the
# tool floor (no role plugins). Permanence = promotion to its own [role.<name>] block. `--cwd` overrides
# the home for a work-targeted run. Omit this block and `--adhoc` errors (the scratch role is opt-in).
[role.adhoc]
cwd = "agents/ad-hoc"
[role.adhoc.claude]

[role.worker]
kind = "child"
place = "tab"
cwd  = "agents/worker"
# [role.worker.claude]
# account = "berg-max"           # DURABLE pin: this seat always launches/recycles on berg-max (see [providers])

[role.lead]
kind  = "conductor"
place = "workspace"
group = "lead"
cwd   = "agents/lead"
[role.lead.claude]
flags = "--effort xhigh"

# A worktree-isolated CODE worker. Config-gated and DEFAULT-OFF: set worktree=true only on roles whose
# `cwd` is a git repo you want each agent to edit in its own branch. The fleet owns the worktree end to
# end (creates <repo>/.worktrees/<label> on branch fleet/<label>, launches the tool there, tears it down
# on `rm --kill`). Pairs naturally with place="workspace". Leave it off for doc/notes roles.
[role.coder]
kind     = "child"
place    = "workspace"
group    = "coders"
cwd      = "code/myrepo"           # a git repo root (relative to [fleet].root, or absolute)
worktree = true                    # opt in. default false. CLI: --worktree / --no-worktree / --worktree-base
# worktree_base          = "main"  # base ref for a NEW branch (default: repo default branch)
# worktree_dir           = ".worktrees"   # where trees live under the repo (gitignored automatically)
# worktree_branch_prefix = "fleet/"       # branch = <prefix><label>

# ----------------------------------------------------------------------------------------------
# [providers] OPTIONAL inference-provider config (usage tracking + per-launch account selection).
# A TOOL has N named providers; each has a TYPE that decides handling:
#   subscription  track the 5h + 7-day windows (%, reset); auth = an OAuth token injected PER LAUNCH
#                 (never a config-dir swap → session logs stay in the tool's default dir).
#   api           metered; windows N/A. track="budget" is a stub (leave room; not built).
#   vertex        just env vars (an env-file); nothing to track.
# `fleet launch <role> --provider <name>` selects one for a launch (omit → the tool's `default`).
# `fleet usage` shows the polled windows. The daemon poll writes ~/.local/state/cmux-fleet/provider-usage.json.
#
# DURABLE per-seat account (the pin): give a role `account = "<name>"` under [role.<r>.<tool>] and that seat
# stays on that account across recycle/revive/launch — it layers ABOVE the tool `default`, so a respawn no
# longer silently reverts to the default. A `--provider <name>` flag is still one-off and wins for that one
# launch. PRECEDENCE:  --provider flag  >  role account pin  >  [providers.<tool>].default.
# A pin naming an account with no [providers.<tool>] block ABORTS loudly (never a silent ambient fallback).
# `fleet config <role>` prints the resolved account and WHERE it came from (flag / role pin / default).
#
# auth = "<method>:<arg>":
#   keychain:<service>  read the tool's OAuth blob from the macOS keychain (the CURRENT logged-in acct;
#                       no launch injection — the tool uses the keychain natively). claude default acct.
#   file:<path>         a long-lived token from `claude setup-token`; relative → under the state dir
#                       (e.g. providers/<name>.token, chmod 0600). Injected at launch as
#                       CLAUDE_CODE_OAUTH_TOKEN via a spawn-time $(cat …) so the secret is never printed.
#   securestorage:<dir> a SECOND claude subscription keyed by CLAUDE_SECURESTORAGE_CONFIG_DIR — namespaces
#                       ONLY the keychain credential (session logs/hooks/settings stay in the default
#                       ~/.claude, no config-dir swap). The dir is a keychain KEY, not a home; it need not
#                       exist on disk. MUST BE SEEDED: log in ONCE per namespace by launching a pane on the
#                       account and running /login inside it. An UNSEEDED namespace has no keychain item, so
#                       claude SILENTLY FALLS BACK to the ambient credential — a launch billing the WRONG
#                       account under a pin. The launch guard detects this (keychain-item existence probe)
#                       and WARNs loudly on every spawn path (never silent; WARN not ABORT, so the seeding
#                       launch itself still runs). Use securestorage for NON-default accounts; keep the
#                       default account on keychain:Claude Code-credentials (its native unsuffixed entry).
#   codex-home:<path>   CODEX_HOME for a codex account. REQUIRED for every codex seat, and never guessed.
#                       SETTLED 2026-07-12 (three seats ran concurrently, none killed another): the ChatGPT
#                       backend keys one active session per DEVICE, the device id (installation_id) is a file
#                       in the codex HOME, so a home IS a credential boundary. Seats sharing a home are one
#                       device and REVOKE EACH OTHER on every login; seats in their own homes coexist.
#                       Convention ~/.codex-<acct>; ~/.codex itself is a legal, first-class value for one seat.
#                       Different PEOPLE may share one team subscription — that is what a team seat is, and it
#                       is fine. The same person in two homes is not. Then: `fleet codex-login <acct>`.
#                       (The old `codex-token:` shared-home path IS the supersession bug and is now refused.)
#   env-file:<path>     source KEY=VALUE lines (vertex: CLAUDE_CODE_USE_VERTEX, project, region).
#
# SECRETS ROADMAP (not built): the file: tokens are a prototype stopgap stored as plain 0600 files.
# Long-term these fold into Berg's SOPS env-var mechanism; the auth DSL leaves room for a `sops:` method.

# [providers.claude]
# default = "berg-max"
# [providers.claude.berg-max]                       # the current logged-in account (no injection)
# type = "subscription"
# auth = "keychain:Claude Code-credentials"
# track = "windows"
# [providers.claude.throwaway]                       # a 2nd account, token minted via `claude setup-token`
# type = "subscription"
# auth = "file:providers/throwaway.token"           # -> ~/.local/state/cmux-fleet/providers/throwaway.token (0600)
# track = "windows"
# [providers.claude.vertex]
# type = "vertex"
# auth = "env-file:~/.claude-vertex.env"
# track = "none"

# [providers.codex]
# default = "worker-a"
# Every codex seat gets its OWN home, or it will supersede the others. `fleet codex-login` (no acct) cycles
# them all and SKIPS any that already verify — a login supersedes, so re-logging a working seat breaks it.
# [providers.codex.worker-a]
# type = "subscription"
# auth = "codex-home:~/.codex-worker-a"
# track = "windows"
# [providers.codex.worker-b]                         # a DIFFERENT PERSON; may share worker-a's team plan
# type = "subscription"
# auth = "codex-home:~/.codex-worker-b"
# track = "windows"
# [providers.codex.desktop]                          # ~/.codex itself is a legal home for exactly ONE seat
# type = "subscription"
# auth = "codex-home:~/.codex"
# track = "windows"
